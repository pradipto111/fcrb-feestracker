generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Center {
  id             Int                    @id @default(autoincrement())
  name           String
  location       String?
  city           String?
  address        String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  addressLine    String?
  displayOrder   Int                    @default(0)
  googleMapsUrl  String?
  isActive       Boolean                @default(true)
  latitude       Float?
  locality       String?
  longitude      Float?
  postalCode     String?
  shortName      String?                @unique
  state          String?
  monthlyMetrics CentreMonthlyMetrics[]
  clubEvents     ClubEvent[]
  coachLinks     CoachCenter[]
  fixtures       Fixture[]
  payments       Payment[]
  weeklyLoads    PlayerWeeklyLoad[]
  posts          Post[]
  scoutingBoards ScoutingBoard[]
  seasonPlans    SeasonPlan[]
  sessions       Session[]
  students       Student[]
  studentStats   StudentStats[]
  trialEvents    TrialEvent[]
  votes          Vote[]

  @@index([shortName])
  @@index([isActive])
  @@index([displayOrder])
}

model Coach {
  id                        Int                       @id @default(autoincrement())
  fullName                  String
  email                     String                    @unique
  passwordHash              String
  role                      Role                      @default(COACH)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  markedAttendance          Attendance[]              @relation("MarkedAttendance")
  clubEvents                ClubEvent[]
  centers                   CoachCenter[]
  createdDevelopmentBlocks  DevelopmentBlock[]        @relation("DevelopmentBlockCreator")
  fixtures                  Fixture[]
  feedbacks                 MonthlyFeedback[]
  publishedFeedbacks        MonthlyFeedback[]         @relation("FeedbackPublisher")
  publishedReports          ParentDevelopmentReport[] @relation("ReportPublisher")
  authoredNotes             PlayerCoachNote[]         @relation("NoteAuthor")
  metricAuditLogs           PlayerMetricAuditLog[]    @relation("AuditLogCreator")
  createdMetricSnapshots    PlayerMetricSnapshot[]    @relation("MetricSnapshotCreator")
  progressRoadmaps          ProgressRoadmap[]         @relation("RoadmapUpdater")
  createdScoutingBoards     ScoutingBoard[]           @relation("ScoutingBoardCreator")
  addedScoutingBoardPlayers ScoutingBoardPlayer[]     @relation("ScoutingBoardPlayerAdder")
  scoutingDecisions         ScoutingDecisionLog[]     @relation("ScoutingDecisionMaker")
  createdSeasonPlans        SeasonPlan[]              @relation("SeasonPlanCreator")
  sessions                  Session[]
  createdSessionLoads       TrainingSessionLoad[]     @relation("SessionLoadCreator")
  trialDecisions            TrialDecisionLog[]        @relation("TrialDecisionMaker")
  createdTrialEvents        TrialEvent[]              @relation("TrialEventCreator")
  trialEventStaff           TrialEventStaff[]         @relation("TrialEventStaff")
  createdTrialTemplates     TrialMetricTemplate[]     @relation("TrialTemplateCreator")
  createdTrialReports       TrialReport[]             @relation("TrialReportCreator")
  revisedTrialReports       TrialReportRevision[]     @relation("TrialReportRevisor")
  createdTrialShortlists    TrialShortlist[]          @relation("TrialShortlistCreator")
  videos                    Video[]
}

model CoachCenter {
  id       Int    @id @default(autoincrement())
  coachId  Int
  centerId Int
  center   Center @relation(fields: [centerId], references: [id])
  coach    Coach  @relation(fields: [coachId], references: [id])

  @@unique([coachId, centerId])
}

model Student {
  id                   Int                       @id @default(autoincrement())
  fullName             String
  dateOfBirth          DateTime?
  phoneNumber          String?
  parentName           String?
  parentPhoneNumber    String?
  email                String?                   @unique
  centerId             Int
  joiningDate          DateTime?
  programType          String?
  monthlyFeeAmount     Int                       @default(0)
  status               StudentStatus             @default(ACTIVE)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  passwordHash         String?
  paymentFrequency     Int                       @default(1)
  churnedDate          DateTime?
  lastFeeDeduction     DateTime?
  walletBalance        Int                       @default(0)
  attendance           Attendance[]
  clubEventPlayers     ClubEventPlayer[]
  fixturePlayers       FixturePlayer[]
  monthlyFeedbacks     MonthlyFeedback[]
  parentReports        ParentDevelopmentReport[]
  payments             Payment[]
  coachNotes           PlayerCoachNote[]
  metricAuditLogs      PlayerMetricAuditLog[]
  metricSnapshots      PlayerMetricSnapshot[]
  weeklyLoads          PlayerWeeklyLoad[]
  progressRoadmap      ProgressRoadmap?
  scoutingBoardPlayers ScoutingBoardPlayer[]
  scoutingDecisions    ScoutingDecisionLog[]
  sessionParticipants  SessionParticipant[]
  center               Center                    @relation(fields: [centerId], references: [id])
  stats                StudentStats[]
  timelineEvents       TimelineEvent[]
  wellnessChecks       WellnessCheck[]
}

model Payment {
  id                Int      @id @default(autoincrement())
  studentId         Int
  centerId          Int
  amount            Int
  paymentDate       DateTime @default(now())
  paymentMode       String
  upiOrTxnReference String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  center            Center   @relation(fields: [centerId], references: [id])
  student           Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([centerId])
}

model FanUser {
  id           Int              @id @default(autoincrement())
  email        String           @unique
  passwordHash String
  role         Role             @default(FAN)
  status       FanAccountStatus @default(ACTIVE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  profile      FanProfile?

  @@index([role])
  @@index([status])
}

model FanProfile {
  id               Int                  @id @default(autoincrement())
  userId           Int                  @unique
  fullName         String
  phone            String?
  city             String?
  centerPreference FanCenterPreference?
  tierId           Int?
  points           Int                  @default(0)
  badges           String[]             @default([])
  streakDays       Int                  @default(0)
  joinedAt         DateTime             @default(now())
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  redemptions      CouponRedemption[]
  badgesEarned     FanBadgeEarned[]
  conversionLeads  FanConversionLead[]
  gameSessions     FanGameSession[]
  onboarding       FanOnboarding?
  pointLedger      FanPointLedger[]
  tier             FanTier?             @relation(fields: [tierId], references: [id])
  user             FanUser              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tierId])
  @@index([joinedAt])
}

model FanTier {
  id              Int             @id @default(autoincrement())
  name            String          @unique
  monthlyPriceINR Int
  yearlyPriceINR  Int
  benefitsJson    Json
  featureFlags    Json
  sortOrder       Int             @default(0)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  onboardings     FanOnboarding[]
  fans            FanProfile[]

  @@index([isActive])
  @@index([sortOrder])
}

model FanSponsor {
  id             Int              @id @default(autoincrement())
  name           String           @unique
  logoAssetKey   String
  brandPrimary   String
  brandSecondary String
  description    String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  couponPools    CouponPool[]
  campaigns      RewardCampaign[]

  @@index([isActive])
}

model RewardCampaign {
  id              Int                @id @default(autoincrement())
  sponsorId       Int
  title           String
  type            RewardCampaignType @default(STATIC)
  copy            String
  rulesJson       Json?
  validFrom       DateTime?
  validTo         DateTime?
  tierEligibility Int[]              @default([])
  isActive        Boolean            @default(true)
  priority        Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  sponsor         FanSponsor         @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@index([sponsorId])
  @@index([isActive])
  @@index([priority])
}

model CouponPool {
  id              Int                @id @default(autoincrement())
  sponsorId       Int
  name            String
  codeType        CouponCodeType
  multiUseCode    String?
  discountType    CouponDiscountType
  discountValue   Int
  conditionsText  String
  tierEligibility Int[]              @default([])
  maxRedemptions  Int?
  expiresAt       DateTime?
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  codes           CouponCode[]
  sponsor         FanSponsor         @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  redemptions     CouponRedemption[]

  @@index([sponsorId])
  @@index([isActive])
  @@index([expiresAt])
}

model CouponCode {
  id           Int        @id @default(autoincrement())
  couponPoolId Int
  code         String
  isUsed       Boolean    @default(false)
  usedAt       DateTime?
  createdAt    DateTime   @default(now())
  pool         CouponPool @relation(fields: [couponPoolId], references: [id], onDelete: Cascade)

  @@unique([couponPoolId, code])
  @@index([couponPoolId])
  @@index([isUsed])
}

model CouponRedemption {
  id           Int                    @id @default(autoincrement())
  fanId        Int
  couponPoolId Int
  codeUsed     String
  redeemedAt   DateTime               @default(now())
  status       CouponRedemptionStatus @default(REDEEMED)
  pool         CouponPool             @relation(fields: [couponPoolId], references: [id])
  fan          FanProfile             @relation(fields: [fanId], references: [id], onDelete: Cascade)

  @@unique([fanId, couponPoolId])
  @@index([fanId])
  @@index([couponPoolId])
  @@index([redeemedAt])
}

model FanQuest {
  id              Int      @id @default(autoincrement())
  title           String
  description     String
  pointsReward    Int      @default(0)
  badgeReward     String?
  unlockRule      String?
  tierEligibility Int[]    @default([])
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
}

model FanGameSession {
  id           Int         @id @default(autoincrement())
  fanId        Int
  gameType     FanGameType
  input        Json?
  result       Json?
  pointsEarned Int         @default(0)
  createdAt    DateTime    @default(now())
  fan          FanProfile  @relation(fields: [fanId], references: [id], onDelete: Cascade)

  @@index([fanId])
  @@index([gameType])
  @@index([createdAt])
}

model FanConversionLead {
  id              Int                     @id @default(autoincrement())
  fanId           Int
  programInterest FanProgramInterest
  status          FanConversionLeadStatus @default(NEW)
  notes           String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  fan             FanProfile              @relation(fields: [fanId], references: [id], onDelete: Cascade)

  @@index([fanId])
  @@index([programInterest])
  @@index([status])
  @@index([createdAt])
}

model FanOnboarding {
  id             Int             @id @default(autoincrement())
  fanId          Int             @unique
  persona        FanPersonaType?
  favoritePlayer String?
  locality       String?
  goals          String[]        @default([])
  assignedTierId Int?
  completedAt    DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  assignedTier   FanTier?        @relation(fields: [assignedTierId], references: [id])
  fan            FanProfile      @relation(fields: [fanId], references: [id], onDelete: Cascade)

  @@index([assignedTierId])
  @@index([completedAt])
}

model FanPointLedger {
  id        Int        @id @default(autoincrement())
  fanId     Int
  delta     Int
  reason    String
  source    String?
  actorId   Int?
  createdAt DateTime   @default(now())
  fan       FanProfile @relation(fields: [fanId], references: [id], onDelete: Cascade)

  @@index([fanId])
  @@index([createdAt])
}

model FanBadgeEarned {
  id        Int        @id @default(autoincrement())
  fanId     Int
  badgeKey  String
  badgeName String?
  source    String?
  earnedAt  DateTime   @default(now())
  fan       FanProfile @relation(fields: [fanId], references: [id], onDelete: Cascade)

  @@unique([fanId, badgeKey])
  @@index([fanId])
  @@index([earnedAt])
}

model MatchdayMoment {
  id           Int       @id @default(autoincrement())
  title        String
  category     String
  mediaUrl     String?
  thumbnailUrl String?
  fixtureId    Int?
  isFeatured   Boolean   @default(false)
  isLocked     Boolean   @default(false)
  unlockAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([fixtureId])
  @@index([isFeatured])
  @@index([createdAt])
}

model DynamicRewardRule {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  title       String
  description String
  rulesJson   Json?
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  actorAdminId Int
  action       String
  entityType   String
  entityId     String
  before       Json?
  after        Json?
  createdAt    DateTime @default(now())

  @@index([actorAdminId])
  @@index([entityType])
  @@index([createdAt])
}

model Session {
  id             Int                  @id @default(autoincrement())
  centerId       Int
  coachId        Int
  sessionDate    DateTime
  startTime      String
  endTime        String
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  description    String?
  programmeId    String?
  title          String
  attendance     Attendance[]
  center         Center               @relation(fields: [centerId], references: [id])
  coach          Coach                @relation(fields: [coachId], references: [id])
  participants   SessionParticipant[]
  sessionLoad    TrainingSessionLoad?
  votes          Vote[]
  wellnessChecks WellnessCheck[]

  @@index([centerId])
  @@index([coachId])
  @@index([sessionDate])
  @@index([programmeId])
}

model SessionParticipant {
  id        Int      @id @default(autoincrement())
  sessionId Int
  studentId Int
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
}

model Attendance {
  id            Int              @id @default(autoincrement())
  sessionId     Int
  studentId     Int
  status        AttendanceStatus @default(ABSENT)
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  markedAt      DateTime         @default(now())
  markedBy      Int
  markedByCoach Coach            @relation("MarkedAttendance", fields: [markedBy], references: [id])
  session       Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student       Student          @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@index([markedBy])
  @@index([markedAt])
}

model Fixture {
  id        Int             @id @default(autoincrement())
  centerId  Int
  coachId   Int
  matchType String
  opponent  String?
  matchDate DateTime
  matchTime String
  venue     String?
  notes     String?
  status    FixtureStatus   @default(UPCOMING)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  center    Center          @relation(fields: [centerId], references: [id])
  coach     Coach           @relation(fields: [coachId], references: [id])
  players   FixturePlayer[]

  @@index([centerId])
  @@index([coachId])
  @@index([matchDate])
}

model FixturePlayer {
  id              Int                   @id @default(autoincrement())
  fixtureId       Int
  studentId       Int
  position        String?
  role            String?
  selectionStatus MatchSelectionStatus  @default(NOT_SELECTED)
  selectionReason MatchSelectionReason?
  notes           String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  fixture         Fixture               @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  student         Student               @relation(fields: [studentId], references: [id])

  @@unique([fixtureId, studentId])
  @@index([fixtureId])
  @@index([studentId])
  @@index([selectionStatus])
}

model ClubEvent {
  id              String            @id @default(uuid())
  type            ClubEventType
  title           String
  startAt         DateTime
  endAt           DateTime?
  allDay          Boolean           @default(false)
  venueName       String?
  venueAddress    String?
  googleMapsUrl   String?
  competition     String?
  opponent        String?
  homeAway        HomeAway?
  teamId          Int?
  centerId        Int?
  status          ClubEventStatus   @default(SCHEDULED)
  notes           String?
  createdByUserId Int
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  center          Center?           @relation(fields: [centerId], references: [id])
  createdBy       Coach             @relation(fields: [createdByUserId], references: [id])
  players         ClubEventPlayer[]

  @@unique([title, startAt])
  @@index([startAt])
  @@index([type])
  @@index([status])
  @@index([centerId])
}

model ClubEventPlayer {
  id        Int       @id @default(autoincrement())
  eventId   String
  studentId Int
  position  String?
  role      String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  event     ClubEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([eventId, studentId])
  @@index([eventId])
  @@index([studentId])
}

model Video {
  id           Int            @id @default(autoincrement())
  title        String
  description  String?
  videoUrl     String?
  platform     VideoPlatform  @default(YOUTUBE)
  category     String?
  thumbnailUrl String?
  createdById  Int
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  fileName     String?
  fileSize     Int?
  fileUrl      String?
  mediaType    DrillMediaType @default(LINK)
  mimeType     String?
  creator      Coach          @relation(fields: [createdById], references: [id])

  @@index([createdById])
  @@index([category])
  @@index([platform])
  @@index([mediaType])
}

model Post {
  id             Int                @id @default(autoincrement())
  title          String?
  description    String?
  mediaType      PostMediaType      @default(IMAGE)
  mediaUrl       String
  platform       PostPlatform?
  centerId       Int?
  createdByRole  Role
  createdById    Int
  approvalStatus PostApprovalStatus @default(PENDING)
  approvedById   Int?
  approvedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  comments       Comment[]
  center         Center?            @relation(fields: [centerId], references: [id])

  @@index([createdById, createdByRole])
  @@index([centerId])
  @@index([approvalStatus])
  @@index([createdAt])
}

model Comment {
  id            Int      @id @default(autoincrement())
  postId        Int
  content       String
  createdByRole Role
  createdById   Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([createdById, createdByRole])
  @@index([createdAt])
}

model Vote {
  id         Int      @id @default(autoincrement())
  sessionId  Int
  voterRole  Role
  voterId    Int
  votedForId Int
  points     Int      @default(1)
  centerId   Int
  createdAt  DateTime @default(now())
  center     Center   @relation(fields: [centerId], references: [id])
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, voterId, voterRole, votedForId])
  @@index([sessionId])
  @@index([votedForId])
  @@index([centerId])
  @@index([createdAt])
}

model StudentStats {
  id            Int       @id @default(autoincrement())
  studentId     Int
  centerId      Int
  totalPoints   Int       @default(0)
  studentVotes  Int       @default(0)
  coachVotes    Int       @default(0)
  sessionsVoted Int       @default(0)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  weeklyPoints  Int       @default(0)
  monthlyPoints Int       @default(0)
  lastVotedAt   DateTime?
  updatedAt     DateTime  @updatedAt
  badges        Badge[]
  center        Center    @relation(fields: [centerId], references: [id])
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, centerId])
  @@index([centerId, totalPoints])
  @@index([centerId, weeklyPoints])
  @@index([centerId, monthlyPoints])
}

model Badge {
  id             Int          @id @default(autoincrement())
  studentStatsId Int
  badgeType      BadgeType
  earnedAt       DateTime     @default(now())
  studentStats   StudentStats @relation(fields: [studentStatsId], references: [id], onDelete: Cascade)

  @@index([studentStatsId])
  @@index([badgeType])
}

model WebsiteLead {
  id                 Int        @id @default(autoincrement())
  source             String     @default("website_join")
  playerName         String
  playerDob          DateTime?
  ageBracket         String?
  guardianName       String
  phone              String
  email              String
  preferredCentre    String
  programmeInterest  String
  playingPosition    String?
  currentLevel       String
  heardFrom          String
  notes              String?
  status             LeadStatus @default(NEW)
  assignedTo         Int?
  internalNotes      String?
  convertedPlayerId  Int?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  skillsShowcaseLink String?

  @@index([status])
  @@index([preferredCentre])
  @@index([programmeInterest])
  @@index([createdAt])
}

model LegacyLead {
  id                     Int        @id @default(autoincrement())
  source                 String     @default("Find Your Legacy")
  name                   String
  phone                  String
  age                    Int
  heightCmInput          Int
  weightKgInput          Int
  heightCmBucket         Int
  weightKgBucket         Int
  matchedPlayerId        String?
  matchedPlayerName      String?
  matchedPlayerPosition  String?
  matchedPlayerArchetype String?
  matchedPlayerLegacy    Json?
  consent                Boolean    @default(false)
  status                 LeadStatus @default(NEW)
  notes                  String?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([matchedPlayerId])
}

model CrmUser {
  id           Int            @id @default(autoincrement())
  fullName     String
  email        String         @unique
  passwordHash String
  role         CrmUserRole    @default(AGENT)
  status       CrmUserStatus  @default(ACTIVE)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  activities   CrmActivity[]
  imports      CrmImportJob[] @relation("CrmImportJobCreator")
  ownedLeads   CrmLead[]      @relation("CrmLeadOwner")
  tasks        CrmTask[]

  @@index([role])
  @@index([status])
}

model CrmSettings {
  id              Int      @id @default(autoincrement())
  stages          Json
  tags            String[] @default([])
  slaHoursByStage Json?
  assignmentRules Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([updatedAt])
}

model CrmLead {
  id                 String            @id @default(uuid())
  sourceType         CrmLeadSourceType
  sourceId           Int
  primaryName        String
  phone              String?
  email              String?
  city               String?
  preferredCentre    String?
  programmeInterest  String?
  stage              CrmLeadStage      @default(NEW)
  status             CrmLeadStatus     @default(OPEN)
  priority           Int               @default(0)
  score              Int?
  ownerId            Int?
  tags               String[]          @default([])
  customFields       Json?
  convertedStudentId Int?
  convertedFanId     Int?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  activities         CrmActivity[]
  owner              CrmUser?          @relation("CrmLeadOwner", fields: [ownerId], references: [id])
  tasks              CrmTask[]

  @@unique([sourceType, sourceId])
  @@index([sourceType])
  @@index([stage])
  @@index([status])
  @@index([ownerId])
  @@index([createdAt])
}

model CrmManualLeadSource {
  id                Int      @id @default(autoincrement())
  primaryName       String
  phone             String?
  email             String?
  preferredCentre   String?
  programmeInterest String?
  raw               Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([createdAt])
  @@index([email])
  @@index([phone])
}

model CrmActivity {
  id                 String          @id @default(uuid())
  leadId             String
  type               CrmActivityType
  occurredAt         DateTime        @default(now())
  title              String?
  body               String?
  metadata           Json?
